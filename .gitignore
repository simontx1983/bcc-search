# Composer — production vendor/ IS committed for GitHub-based deploys
# (Deployer for Git ships the zip from the repo, doesn't run composer
# server-side). Dev-only paths below are gitignored so running
# `composer install` locally to restore phpstan doesn't dirty git status.
/vendor/bin/
/vendor/phpstan/
/vendor/php-stubs/
/vendor/szepeviktor/
/composer.lock

# PHPUnit
/phpunit.xml
/.phpunit.result.cache

# PHPStan
/phpstan.neon
/phpstan-baseline.neon
/phpstan/
/php-stubs/
/szepeviktor/

# Tests
/tests/
