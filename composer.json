{
    "name": "blue-collar-crypto/bcc-search",
    "description": "Live search for BCC PeepSo project pages",
    "type": "wordpress-plugin",
    "license": "proprietary",
    "require": {
        "php": ">=8.1"
    },
    "autoload": {
        "psr-4": {
            "BCC\\Search\\": "app/"
        }
    },
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true
    },
    "require-dev": {
        "phpstan/phpstan": "^2.0",
        "szepeviktor/phpstan-wordpress": "^2.0"
    }
}
